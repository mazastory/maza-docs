{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "./dist-server",
    "resolveJsonModule": true,
    "noEmit": false,
    "ignoreDeprecations": "6.0"
  },
  "include": ["server/**/*", "src/lib/supabase.ts"]
}
