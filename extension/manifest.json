{
  "manifest_version": 3,
  "name": "MAZA",
  "version": "1.1.0",
  "description": "AI 블로그 운영 OS — MAZA Dumb Bridge",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "alarms",
    "sidePanel"
  ],
  "host_permissions": [
    "https://*.tistory.com/*",
    "https://*.wordpress.com/*",
    "https://*.blogspot.com/*",
    "http://localhost:3001/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.tistory.com/manage/*"],
      "js": ["content/injector.js"],
      "all_frames": true,
      "run_at": "document_start"
    },
    {
      "matches": ["http://localhost:5174/*", "*://mazastudio.kr/*", "*://*.mazastudio.kr/*"],
      "js": ["content/sync_token.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "action": {
    "default_title": "MAZA Control",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
